{
  "name": "ai-diff-agent",
  "displayName": "AI Diff Agent",
  "description": "Agentic Diff Engine for LLM code application with Human-in-the-loop control.",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-diff-agent-sidebar-container",
          "title": "AI Diff Agent",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "ai-diff-agent-sidebar-container": [
        {
          "type": "webview",
          "id": "ai-diff-agent-sidebar-view",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "ai-diff-agent.start",
        "title": "AI Diff Agent: Focus Chat"
      },
      {
        "command": "ai-diff-agent.action.accept",
        "title": "AI Diff Agent: Accept Change"
      },
      {
        "command": "ai-diff-agent.action.reject",
        "title": "AI Diff Agent: Reject Change"
      },
      {
        "command": "ai-diff-agent.action.acceptAll",
        "title": "AI Diff Agent: Accept All Pending Changes"
      },
      {
        "command": "ai-diff-agent.action.rejectAll",
        "title": "AI Diff Agent: Reject All Pending Changes"
      },
      {
        "command": "ai-diff-agent.showLog",
        "title": "AI Diff Agent: Show Output Log"
      }
    ],
    "keybindings": [
      {
        "command": "ai-diff-agent.action.acceptAll",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "view.ai-diff-agent-sidebar-view.visible"
      },
      {
        "command": "ai-diff-agent.action.rejectAll",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "view.ai-diff-agent-sidebar-view.visible"
      }
    ],
    "configuration": {
      "title": "AI Diff Agent",
      "properties": {
        "aiDiffAgent.autoScroll": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scroll to the bottom of the chat when new messages arrive."
        },
        "aiDiffAgent.strictParsing": {
          "type": "boolean",
          "default": false,
          "description": "Enforce strict XML parsing. If false, the agent attempts to recover from malformed markdown fences."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build:webview": "vite build",
    "build:extension": "tsc -p ./",
    "build": "npm run build:webview && npm run build:extension",
    "watch:webview": "vite build --watch",
    "watch:extension": "tsc -watch -p ./",
    "lint": "eslint src --ext ts,tsx",
    "test": "mocha -r ts-node/register tests/**/*.spec.ts"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.44.0",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.80.0",
    "@vitejs/plugin-react": "^4.2.1",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3",
    "vite": "^8.1.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "serialize-javascript": "^7.0.6"
  }
}
