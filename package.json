{
  "name": "ai-diff-agent",
  "displayName": "AI Diff Agent",
  "description": "Agentic Diff Engine for LLM code application with Human-in-the-loop control.",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-diff-agent-sidebar-container",
          "title": "AI Diff Agent",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "ai-diff-agent-sidebar-container": [
        {
          "type": "webview",
          "id": "ai-diff-agent-sidebar-view",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "ai-diff-agent.start",
        "title": "AI Diff Agent: Focus Chat"
      },
      {
        "command": "ai-diff-agent.action.acceptAll",
        "title": "AI Diff Agent: Accept All Pending Changes"
      },
      {
        "command": "ai-diff-agent.action.rejectAll",
        "title": "AI Diff Agent: Reject All Pending Changes"
      },
      {
        "command": "ai-diff-agent.showLog",
        "title": "AI Diff Agent: Show Output Log"
      }
    ],
    "keybindings": [
      {
        "command": "ai-diff-agent.action.acceptAll",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "view.ai-diff-agent-sidebar-view.visible"
      },
      {
        "command": "ai-diff-agent.action.rejectAll",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "view.ai-diff-agent-sidebar-view.visible"
      }
    ],
    "configuration": {
      "title": "AI Diff Agent",
      "properties": {
        "aiDiffAgent.behavior.autoScroll": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scroll to the bottom of the chat when new messages arrive."
        },
        "aiDiffAgent.behavior.compactMode": {
          "type": "boolean",
          "default": false,
          "description": "Reduce visual padding and gaps to show more operations on screen."
        },
        "aiDiffAgent.engine.strictParsing": {
          "type": "boolean",
          "default": false,
          "description": "Enforce strict XML parsing. Disables recovery for malformed markdown blocks."
        },
        "aiDiffAgent.engine.maxBackupRetentionDays": {
          "type": "integer",
          "default": 7,
          "description": "Number of days to keep transaction backups before purging."
        }
      }
    }
  
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build:webview": "vite build",
    "build:extension": "npx esbuild src/extension/extension.ts --bundle --platform=node --target=node16 --external:vscode --outfile=out/extension/extension.js --sourcemap",
    "build": "npm run build:webview && npm run build:extension",
    "watch:webview": "vite build --watch",
    "watch:extension": "npx esbuild src/extension/extension.ts --bundle --platform=node --target=node16 --external:vscode --outfile=out/extension/extension.js --sourcemap --watch",
    "lint": "eslint src --ext ts,tsx",
    "test": "mocha -r ts-node/register -r tests/setup.ts tests/**/*.spec.ts"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.44.0",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "react": "^19.x",
    "react-dom": "^19.x",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.x",
    "@types/react": "^19.x",
    "@types/react-dom": "^19.x",
    "@types/vscode": "^1.x",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "esbuild": "^0.28.1",
    "mocha": "^11.7.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.0"
  }
}
