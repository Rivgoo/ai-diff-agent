<workspace_edit>
    <!-- 
      1. Update AppLogger with heavy noise in path declaration to test resilient resolving.
         Path contains: leading slashes, project root duplicate name, mixed case (UTILS), 
         redundant double slashes, wrong filename casing (Logger.ts vs logger.ts), 
         and a trailing whitespace with carriage return (\r).
         This rigorously tests PathNormalizer, ResilientPathResolver, and FuzzyMatcher at once.
    -->
    <update_file path="/ai-diff-agent/src//modules/core/UTILS/logging/Logger.ts \r">
        <change>
            <search>
export type LogLevel = 'info' | 'warn' | 'error';

export class AppLogger {
    public static log(message: string, level: LogLevel = 'info'): void {
        const timestamp = new Date().toISOString();
        console.log(`[${timestamp}] [${level.toUpperCase()}] ${message}`);
    }
}
            </search>
            <replace>
export type LogLevel = 'info' | 'warn' | 'error' | 'debug';

export class AppLogger {
    public static log(message: string, level: LogLevel = 'info'): void {
        const timestamp = new Date().toISOString();
        if (level === 'debug') {
            console.debug(`[${timestamp}] [DEBUG] ${message}`);
        } else {
            console.log(`[${timestamp}] [${level.toUpperCase()}] ${message}`);
        }
    }
}
            </replace>
        </change>
    </update_file>

